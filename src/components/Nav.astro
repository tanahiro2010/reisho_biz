---
const links = [
  { href: '#services', label: 'サービス' },
  { href: '#profile', label: '所長について' },
  { href: '#voice', label: 'お客様の声' },
  { href: '#contact', label: 'お問い合わせ' },
];
---

<header class="nav">
  <div class="nav__inner">
    <a href="#" class="nav__logo">冷笑</a>
    <button class="nav__toggle" id="menuToggle" aria-label="メニューを開く">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav class="nav__links" id="navLinks">
      {links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 64px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .nav__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 40px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__logo {
    font-family: var(--font-serif);
    font-size: 20px;
    line-height: 1;
    color: var(--text);
  }

  .nav__links {
    display: flex;
    gap: 28px;
  }

  .nav__links a {
    font-size: 13px;
    line-height: 1;
    color: var(--muted);
    transition: color 0.15s;
  }

  .nav__links a:hover {
    color: var(--text);
    text-decoration: underline;
  }

  .nav__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav__toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--text);
    transition: transform 0.2s;
  }

  @media (max-width: 768px) {
    .nav__inner {
      padding: 0 20px;
    }

    .nav__toggle {
      display: flex;
    }

    .nav__links {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
    }

    .nav__links.open {
      display: flex;
    }

    .nav__links a {
      display: block;
      padding: 16px 20px;
      border-top: 1px solid var(--border);
      font-size: 14px;
    }
  }
</style>

<script>
  document.getElementById('menuToggle').addEventListener('click', function () {
    const links = document.getElementById('navLinks');
    links.classList.toggle('open');
    this.setAttribute(
      'aria-label',
      links.classList.contains('open') ? 'メニューを閉じる' : 'メニューを開く'
    );
  });
</script>
